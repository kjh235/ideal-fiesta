{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.org/schemas/information.schema.json",
  "title": "Information Concept",
  "type": "object",
  "required": ["id", "term", "definition", "confidentiality"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^INF-[0-9]{3}$"
    },
    "term": {
      "type": "string",
      "minLength": 2
    },
    "definition": {
      "type": "string",
      "minLength": 15
    },
    "confidentiality": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    },
    "attributes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "owner_org_id": {
      "type": "string",
      "pattern": "^ORG-[0-9]{3}$"
    }
  }
}
